# ============================================================================
# DJANGO SETTINGS
# ============================================================================

# SECURITY: Generate a new secret key using:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-generated-secret-key-here

# Set to True in production (with HTTPS)
DEBUG=False

# Comma-separated list of allowed hostnames (for Render, use your domain)
ALLOWED_HOSTS=your-domain.onrender.com,www.your-domain.onrender.com

# ============================================================================
# DATABASE (Render provides PostgreSQL)
# ============================================================================

# PostgreSQL connection string from Render
# Format: postgresql://username:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_db

# ============================================================================
# EMAIL CONFIGURATION (for contact form)
# ============================================================================

# Gmail setup:
# 1. Enable 2-factor authentication on your Google account
# 2. Generate app-specific password at: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password below (not your regular Gmail password)

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# Alternative: For other email providers, adjust EMAIL_HOST and EMAIL_PORT
# Outlook: EMAIL_HOST=smtp-mail.outlook.com, EMAIL_PORT=587
# SendGrid: EMAIL_HOST=smtp.sendgrid.net, EMAIL_PORT=587

# ============================================================================
# SECURITY SETTINGS (for production with HTTPS)
# ============================================================================

# Enable these when using HTTPS (Render provides free SSL)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# HSTS security header (optional but recommended for HTTPS)
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ============================================================================
# MEDIA FILE STORAGE (optional - for production persistence)
# ============================================================================

# For persistent media storage on Render, consider using S3 or similar
# Current setup uses local filesystem which won't persist across deploys
# If you want to add S3 storage, install boto3 and set these:
# USE_S3=True
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
# AWS_S3_REGION_NAME=us-east-1


RENDER_EXTERNAL_HOSTNAME=https://portfolioproject-g5ir.onrender.com